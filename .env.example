# OPENROUTER_API_KEY: Required for OpenRouter API calls.
# Users configure this via the Secrets panel in the AI Studio UI.
OPENROUTER_API_KEY=

# OPENROUTER_MODEL: The model to use from OpenRouter.
OPENROUTER_MODEL=stepfun/step-3.5-flash:free

# GOOGLE_API_KEY: Required for Gemini and Embeddings.
GOOGLE_API_KEY=

# PINECONE_API_KEY: Required for Pinecone vector database.
PINECONE_API_KEY=

# PINECONE_HOST: The host URL for your Pinecone index.
PINECONE_HOST=https://careerpath-ai-io1vpog.svc.aped-4627-b74a.pinecone.io

# PINECONE_INDEX_NAME: The name of your Pinecone index.
PINECONE_INDEX_NAME=careerpath-ai

# ENV: Environment setting (development/production).
ENV=development

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
